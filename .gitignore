# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Environments
.venv/
venv/
env/

# Claude Code local dir: machine-specific launcher + regeneratable impeccable
# skill (recreate with `npx impeccable install`). Kept out of version control.
.claude/

# Generated experiment configs (regenerate with experiments/generate_configs.py)
configs/generated/

# Heavy experiment artifacts (keep metrics/ and selected figures/ in git)
results/checkpoints/
results/predictions/
results/logs/

# Anomaly intermediate artifacts (aggregated residuals / val predictions)
results/anomaly/residuals/
results/anomaly/predictions/
results/anomaly/multimodel_residuals/

# Per-run intermediate artifacts (regenerate with the matrix runners / analysis).
# Only per-run forecast/loss plots and per-run metric snapshots are ignored;
# committed EDA and efficiency figures are re-included via the negations below.
results/figures/*.png
!results/figures/eda_*.png
!results/figures/efficiency_*.png
!results/figures/input_len_ablation_*.png
!results/figures/attention_*.png
!results/figures/tcn_comparison_*.png
results/metrics/*_metrics.json
results/metrics/per_horizon_metrics.csv

# Isolated external-validity training run (ETTm); only the summary tables under
# results/external_validity/ are committed, not the heavy per-run artifacts.
results_ettm/

# Isolated input-length ablation run; only results/sensitivity/ summaries committed.
results_inputlen/

# Isolated focused TCN comparison run; only results/comparison/ summary committed.
results_tcn/

# OS
.DS_Store

# Harness probe artifact
__probe__.txt
